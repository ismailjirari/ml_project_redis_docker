# Create .gitignore file
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec

# Virtual Environment
backend/venv/
venv/

# Environment variables
.env
.env.local
.env.*.local

# Large media files
*.mov
*.mp4
*.avi
*.mkv
*.flv
*.wmv
ml_video.mov

# Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Docker
*.log
docker-compose.override.yml
EOF